// ============================================================
// FileHub — Prisma Schema
// Provider : PostgreSQL
// Models   : User, File  (exactly 2 — no extras)
// ============================================================

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"

}

// ------------------------------------------------------------
// User
// Stores one record per registered account.
// Synced from Clerk on first sign-in / onboarding completion.
// ------------------------------------------------------------
model User {
  /// Primary key — UUID generated by the database.
  id           String  @id @default(uuid())

  /// The immutable user ID issued by Clerk (e.g. "user_2abc…").
  /// Unique: one Clerk identity maps to exactly one User row.
  clerkUserId  String  @unique

  /// The user's email address, sourced from Clerk.
  /// Unique: no two accounts may share the same address.
  email        String  @unique

  /// Display name chosen by the user (full name or nickname).
  name         String

  /// URL-safe handle chosen during onboarding.
  username     String

  /// Tracks whether the user has completed the onboarding flow.
  /// Defaults to false; set to true after onboarding is done.
  onboarded    Boolean @default(false)

  /// All files uploaded by this user (one-to-many).
  files        File[]
}

// ------------------------------------------------------------
// File
// Represents a single uploaded file belonging to a User.
// Deleting the owner (User) cascades and removes their files.
// ------------------------------------------------------------
model File {
  /// Primary key — UUID generated by the database.
  id             String   @id @default(uuid())

  /// Human-readable title for the file, set by the uploader.
  title          String

  /// Optional description / notes about the file.
  description    String

  /// URL of the cover image chosen for this file's public page.
  coverImageURL  String

  /// The CDN URL returned by UploadThing after a successful upload.
  /// Anyone with the public link uses this URL to download the file.
  fileURL        String

  /// Number of times this file has been downloaded.
  /// Incremented server-side on each download; defaults to 0.
  downloads      Int      @default(0)

  /// Timestamp of when the file record was created.
  createdAt      DateTime @default(now())

  /// Foreign key — references the User who uploaded the file.
  userId         String

  /// Relation field linking back to the owning User.
  /// onDelete: Cascade ensures files are removed when the user is deleted.
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
